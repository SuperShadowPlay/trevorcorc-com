---
import type { CollectionEntry } from 'astro:content';
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import FormattedDate from '../components/FormattedDate.astro';
import Header from '../components/Header.astro';

type Props = CollectionEntry<'blog'>['data'];

const { title, description, pubDate, updatedDate } = Astro.props;
---

<html lang="en">
	<head>
		<BaseHead title={title} description={description} />
		<style>
			main {
				max-width: 98vw;
				margin: 0;
			}
			.prose {
				min-width: 50vw;
				max-width: 50em;
				margin: auto;
				padding: 1em;
			}
			.header {
				margin-bottom: 1em;
				padding: 1em 0;
				text-align: center;
				line-height: 1;
				color: var(--text);
			}
			.header h1 {
				margin: 0 0 0.2em 0;
				font-size: 3.052em;
			}
			.description {
				line-height: 1.5em;
				margin: 0 0 0em 0;
			}
			.date {
				margin-bottom: 0.5em;
				color: var(--accent);
			}
			.last-updated-on {
				margin-top: 0.5em;
				font-style: italic;
				font-size: 0.8em;
			}

		</style>
	</head>

	<body>
		<Header />
		<main>
			<article>
				<div class="prose">
					<div class="header">
						<div class="title">
							<div class="date">
								<FormattedDate date={pubDate} />
								{
									updatedDate && (
										<div class="last-updated-on">
											Updated <FormattedDate date={updatedDate} />
										</div>
									)
								}
							</div>
							<h1>{title}</h1>
						</div>
						<div class="description">
							<p>{description}</p>
						</div>
						<hr />
					</div>
					<div class="body">
						<slot />
					</div>
				</div>
			</article>
		</main>
		<Footer />
	</body>
</html>
